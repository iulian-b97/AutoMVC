@{ 
    Layout = "/Views/Shared/_Layout.cshtml";
}


        <div class="row" style="margin-top:8rem; border-radius:10px;">
            <div class="col-md-8 offset-md-2">
                <div class="card login-logout-tab bg-main navbar-transparent">
                    <div class="card-header">
                        <ul class="nav nav-tabs card-header-tabs">
                            <li class="nav-item">
                                <a class="nav-link" style="color:deepskyblue" href='/Identity/Account/Login'>Sign In</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" style="color:deepskyblue" href='/Identity/Account/Register'>Sign Up</a>
                            </li>
                        </ul>
                    </div>
                    <div class="card-content" style="height:20rem;">
                        <div class="row">
                            <div class="col-md-12"">
                                @RenderBody()
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>


@section Scripts{ 
    @RenderSection("Scripts", required: false)

<script>
    $(function () {
        var current = location.pathname;
        $('.nav-tabs li a').each(function () {
            var $this = $(this);
            if (current.indexOf($this.attr('href')) !== -1) {
                $this.addClass('active');
            }
        })
    })
</script>

}